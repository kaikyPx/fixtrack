{
  "name": "fixtrack-backend",
  "version": "1.0.0",
  "description": "Backend API for FixTrack Pro",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
